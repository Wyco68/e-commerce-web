# Copy these into Render → Environment (Web Service)
# Generate APP_KEY locally: php artisan key:generate --show

APP_NAME=CarPart
APP_ENV=production
APP_DEBUG=false
# Required — no quotes in Render dashboard. Must start with base64:
# Generate: php artisan key:generate --show
APP_KEY=base64:YOUR_KEY_HERE
# Required — your public Render URL (no trailing slash)
APP_URL=https://YOUR-SERVICE.onrender.com
APP_DEMO_MODE=true

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Demo profile — SQLite, no Redis/Reverb (fast free-tier deploy)
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# database sessions avoid file-permission issues on Render; requires sessions table (migrate)
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log

# Optional: external MySQL instead of SQLite
# DB_CONNECTION=mysql
# DB_HOST=
# DB_PORT=3306
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

# Optional: Redis + Reverb (second Render service required for Reverb)
# SESSION_DRIVER=redis
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# REDIS_URL=
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=YOUR-SERVICE.onrender.com
# REVERB_PORT=443
# REVERB_SCHEME=https
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_PORT="${REVERB_PORT}"
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"
