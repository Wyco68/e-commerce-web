# =============================================================================
# CarPart — paste into Render → Web Service → Environment → "Add from .env"
# After saving: Manual Deploy (rebuild) so VITE_* are baked into JS.
# Docs: docs/HOSTING-RENDER.md · docs/UPSTASH-PUSHER.md
# =============================================================================
# Replace only:
#   APP_URL          → your https://….onrender.com (no trailing slash)
#   APP_KEY          → php artisan key:generate --show
#   PUSHER_*         → from Pusher dashboard (see docs/UPSTASH-PUSHER.md)
#   REDIS_URL        → full Upstash UPSTASH_REDIS_URL (rediss://…) if enabling Redis
# =============================================================================

APP_NAME=CarPart
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://YOUR-SERVICE.onrender.com
APP_DEMO_MODE=true

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

REDIS_CLIENT=predis
# Optional Redis (enable by switching CACHE_STORE/SESSION_DRIVER below)
# REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

SESSION_DRIVER=cookie
# Demo uses 30 min idle (APP_DEMO_MODE=true overrides via DEMO_SESSION_LIFETIME)
SESSION_LIFETIME=30
DEMO_SESSION_LIFETIME=30
NOTIFICATION_READ_RETENTION_DAYS=10
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
CACHE_STORE=file
QUEUE_CONNECTION=sync
RENDER=true

BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_SCHEME=https
PUSHER_PORT=443

VITE_APP_NAME=CarPart
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=mt1
VITE_PUSHER_SCHEME=https

FILESYSTEM_DISK=local
MAIL_MAILER=log
