# =============================================================================
# CarPart — complete Render Web Service environment
# Paste into Render → your service → Environment → Add from .env
# Docs: docs/HOSTING-RENDER.md · docs/UPSTASH-PUSHER.md
# =============================================================================
#
# Rules:
#   • No quotes around values (especially APP_KEY)
#   • APP_KEY must start with base64:
#   • Use Upstash REDIS_URL (rediss://…), NOT REST URL/token
#   • VITE_PUSHER_* must match PUSHER_* — redeploy after changing them
#
# Generate APP_KEY locally: php artisan key:generate --show
# =============================================================================

# --- App ---
APP_NAME=CarPart
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:PASTE_44_CHAR_KEY_FROM_artisan_key_generate
APP_URL=https://YOUR-SERVICE.onrender.com
APP_DEMO_MODE=true

# --- Logging ---
LOG_CHANNEL=stderr
LOG_LEVEL=info

# --- Database (SQLite demo; no MySQL on free tier) ---
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# --- Upstash Redis (console → database → UPSTASH_REDIS_URL / rediss://…) ---
REDIS_CLIENT=predis
REDIS_URL=rediss://default:PASTE_REDIS_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# --- Session / cache / queue ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
CACHE_STORE=redis
QUEUE_CONNECTION=sync

# --- Render production tweaks (also set in render.yaml) ---
RENDER=true

# --- Pusher Channels (dashboard.pusher.com → your app → App Keys) ---
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=PASTE_APP_ID
PUSHER_APP_KEY=PASTE_APP_KEY
PUSHER_APP_SECRET=PASTE_APP_SECRET
PUSHER_APP_CLUSTER=mt1
PUSHER_SCHEME=https
PUSHER_PORT=443

# --- Vite / Echo (same key & cluster as above; baked in at Docker BUILD) ---
VITE_APP_NAME=CarPart
VITE_PUSHER_APP_KEY=PASTE_SAME_AS_PUSHER_APP_KEY
VITE_PUSHER_APP_CLUSTER=mt1
VITE_PUSHER_SCHEME=https

# --- Mail / files (demo: no outbound email) ---
FILESYSTEM_DISK=local
MAIL_MAILER=log

# =============================================================================
# Do NOT set on Render (wrong or unused for this stack):
#   UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN  → HTTP API, not Laravel
#   REDIS_HOST / REDIS_PASSWORD alone                    → use REDIS_URL instead
#   SESSION_DRIVER=database / cookie                     → use redis
#   SESSION_SECURE_COOKIE=true                           → causes 419 behind Render TLS
#   BROADCAST_CONNECTION=log / reverb                    → use pusher
#   VITE_REVERB_*                                        → replaced by VITE_PUSHER_*
# =============================================================================
